---
import Base from '../layouts/Base.astro';
import NiflheimConversations from '../components/NiflheimConversations';
---

<Base title="YGGDREAD — Niflheim" fullHeight={true}>

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="tl-l">
      <a href="/" class="back">[&lt;- BACK TO ROOT]</a>
      <span class="crumb"><span>niflheim</span> // conversations // ascii_logs</span>
    </div>
    <div class="t-logo">YGGDREAD</div>
  </div>

  <!-- CONVERSATIONS -->
  <NiflheimConversations client:load />

</Base>

<style>
  :global(body.full-height) {
    display: flex;
    flex-direction: column;
  }

  .topbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: .6rem 1.5rem;
    border-bottom: 1px solid var(--dim);
    background: var(--void);
    flex-shrink: 0; z-index: 10;
    font-size: .55rem; letter-spacing: .2em;
  }
  .tl-l { display: flex; align-items: center; gap: 1.5rem; }
  .back { color: rgba(184,92,0,.55); text-decoration: none; transition: color .2s; }
  .back:hover { color: var(--amber3); }
  .crumb { color: var(--dim); }
  .crumb span { color: rgba(184,92,0,.55); }
  .t-logo {
    font-family: var(--font-vt); font-size: 1.3rem; letter-spacing: .2em;
    color: var(--amber3); text-shadow: 0 0 10px var(--amber);
  }

  @media(max-width:768px) {
    .topbar { padding: .5rem 1rem; font-size: .5rem; }
    .t-logo { font-size: 1.1rem; }
  }

  @media(max-width:640px) {
    .topbar {
      flex-direction: column;
      align-items: stretch;
      gap: .3rem;
      padding: .4rem .8rem;
    }
    .tl-l {
      flex-direction: column;
      gap: .3rem;
    }
    .t-logo {
      font-size: .95rem;
      text-align: center;
      order: -1;
      padding-bottom: .3rem;
      border-bottom: 1px solid rgba(74,58,32,.25);
    }
    .back { text-align: center; }
    .crumb { display: none; }
  }
</style>
