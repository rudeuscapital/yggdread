</Base>

<style>
  /* NAV */
  nav {
    position: fixed; top: 0; width: 100%; z-index: 1000;
    background: var(--void);
    border-bottom: 1px solid var(--dim);
    padding: .65rem 2rem;
    display: flex; justify-content: space-between; align-items: center;
  }
  .nav-l { display: flex; align-items: center; gap: 2rem; }
  .nav-logo {
    font-family: var(--font-vt); font-size: 1.6rem; letter-spacing: .2em;
    color: var(--amber3); text-decoration: none;
    text-shadow: 0 0 10px var(--amber), 0 0 25px rgba(184,92,0,.4);
    animation: logoGlow 3s ease-in-out infinite;
  }
  @keyframes logoGlow {
    0%,100%{ text-shadow:0 0 10px var(--amber),0 0 25px rgba(184,92,0,.4); }
    50%{ text-shadow:0 0 20px var(--amber2),0 0 45px rgba(184,92,0,.7); }
  }
  .nav-stat { font-size: .55rem; letter-spacing: .18em; color: var(--dim); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a { font-size: .6rem; letter-spacing: .25em; color: var(--dim); text-decoration: none; transition: color .2s; }
  .nav-links a:hover { color: var(--amber3); }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 5rem 1rem 3rem;
    position: relative; overflow: hidden;
  }
  .hero-inner { position: relative; z-index: 2; text-align: center; }

  .big-title {
    font-size: clamp(.38rem, 1.1vw, .72rem); line-height: 1.15; white-space: pre;
    color: var(--amber3);
    text-shadow: 0 0 8px var(--amber), 0 0 20px rgba(184,92,0,.45);
    animation: fadeUp 1.6s ease both, titleFlk 8s 5s infinite;
  }
  @keyframes fadeUp {
    from { opacity:0; transform:translateY(18px); filter:blur(4px); }
    to   { opacity:1; transform:translateY(0);    filter:blur(0); }
  }
  @keyframes titleFlk {
    0%,90%,100%{ text-shadow:0 0 8px var(--amber),0 0 20px rgba(184,92,0,.45); }
    91%{ text-shadow:none; opacity:.5; }
    92%{ text-shadow:0 0 8px var(--amber); }
    93%{ text-shadow:none; opacity:.3; }
    94%{ text-shadow:0 0 8px var(--amber),0 0 20px rgba(184,92,0,.45); }
  }

  .hero-badge {
    font-size: clamp(.5rem, .9vw, .65rem); white-space: pre;
    color: var(--dim); animation: fadeUp 1.6s .3s both; margin-top: .4rem;
  }
  .hero-tag {
    font-size: .68rem; color: rgba(212,201,168,.4);
    line-height: 1.75; margin-top: 1.5rem; max-width: 58ch;
    animation: fadeUp 1.6s .6s both;
  }
  .hero-tag em { color: var(--amber2); font-style: normal; }
  .hero-desc {
    margin-top: 2.5rem; font-size: .6rem;
    color: var(--dim); letter-spacing: .3em;
    animation: fadeUp 1.6s .9s both;
    display: flex; flex-direction: column; align-items: center; gap: .3rem;
  }
  .dpipe { color: var(--amber); font-size: 1rem; }

  /* SECTIONS */
  .sec { max-width: 880px; margin: 0 auto; padding: 5rem 2rem; }

  .ascii-panel h2 {
    font-family: var(--font-vt); font-size: clamp(1.3rem, 2.8vw, 1.9rem);
    color: var(--amber3); letter-spacing: .07em; margin-bottom: 1rem; line-height: 1.2;
  }
  .ascii-panel h2 em { color: var(--bone); font-style: normal; }
  .ascii-panel p { font-size: .7rem; line-height: 2; color: rgba(212,201,168,.5); margin-bottom: .9rem; }
  .ascii-panel p strong { color: var(--amber2); font-weight: normal; }

  .aart {
    white-space: pre; font-size: clamp(.35rem, .85vw, .58rem);
    line-height: 1.25; color: var(--amber);
    margin: 2rem 0; opacity: .72; overflow-x: auto; letter-spacing: .04em;
  }

  /* TERMINAL */
  .term { border: 1px solid var(--amber); background: rgba(0,0,0,.95); margin: 3rem 0; position: relative; overflow: hidden; }
  .term-bar { background: var(--amber); color: var(--void); padding: .3rem 1rem; font-size: .57rem; letter-spacing: .28em; display: flex; justify-content: space-between; }
  .term-body { padding: 1.1rem 1.5rem; font-size: .66rem; }
  .tl { margin-bottom: .28rem; letter-spacing: .04em; }
  .tl.w { color: var(--amber2); }
  .tl.o { color: rgba(212,201,168,.45); padding-left: 1rem; }
  .tl.e { color: var(--blood); }
  .tl.c { color: var(--bone); }
  .tcur { display: inline-block; width: .5em; height: 1em; background: var(--amber3); vertical-align: text-bottom; }
  .term::after {
    content: ''; position: absolute; left: 0; right: 0; height: 2px;
    background: rgba(224,120,0,.12);
    animation: tscan 4s linear infinite; pointer-events: none;
  }
  @keyframes tscan { 0%{top:0;} 100%{top:100%;} }

  /* ART GRID */
  .art-sec { max-width: 980px; margin: 0 auto; padding: 0 2rem 6rem; }
  .art-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: var(--dim); margin-top: 2rem; }
  .acell { background: var(--void); padding: 1rem; cursor: pointer; transition: background .2s; position: relative; min-height: 200px; overflow: hidden; }
  .acell:hover { background: rgba(184,92,0,.06); }
  .acell:hover .ca { color: var(--amber3); text-shadow: 0 0 6px var(--amber); }
  .acell:hover .cc { color: var(--amber2); }
  .acell.feat { grid-column: span 2; grid-row: span 2; }
  .ca { white-space: pre; font-size: clamp(.32rem,.85vw,.55rem); line-height: 1.2; color: var(--amber); letter-spacing: .04em; transition: color .2s, text-shadow .2s; }
  .acell.feat .ca { font-size: clamp(.36rem,.95vw,.6rem); }
  .cc { position: absolute; bottom: .5rem; left: .8rem; right: .8rem; font-size: .48rem; letter-spacing: .18em; color: var(--dim); border-top: 1px dashed rgba(74,58,32,.3); padding-top: .3rem; transition: color .2s; }

  .cta-wrap { text-align: center; margin: 3rem 0 2rem; }

  /* SUPPORTERS */
  .sup-sec { max-width: 880px; margin: 0 auto; padding: 3rem 2rem 6rem; }
  .sup-grid { display: flex; gap: 3rem; flex-wrap: wrap; justify-content: center; margin-top: 2rem; }
  .sup { text-align: center; cursor: pointer; opacity: .38; transition: opacity .2s; }
  .sup:hover { opacity: 1; }
  .sup-art { white-space: pre; font-size: .48rem; line-height: 1.2; color: var(--amber); }
  .sup-name { font-size: .52rem; letter-spacing: .2em; color: var(--dim); margin-top: .4rem; }

  /* CONTRACT ADDRESS */
  .ca-sec { max-width: 880px; margin: 0 auto; padding: 0 2rem 3rem; }
  .ca-box {
    border: 1px dashed var(--dim);
    padding: 1.2rem 2rem;
    text-align: center;
    background: rgba(0,0,0,.5);
  }
  .ca-label {
    font-size: .5rem; letter-spacing: .45em; color: var(--dim); margin-bottom: .6rem;
  }
  .ca-label::before { content: '[ '; }
  .ca-label::after { content: ' ]'; }
  .ca-value {
    font-family: var(--font-vt); font-size: 1.1rem;
    letter-spacing: .15em; color: var(--amber2);
  }

  /* FOOTER */
  footer {
    border-top: 1px dashed var(--dim); padding: 1.4rem 2rem;
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 1rem; font-size: .52rem; letter-spacing: .18em; color: var(--dim);
  }
  .f-logo { font-family: var(--font-vt); font-size: 1.1rem; color: var(--amber); }
  .f-social { display: flex; gap: 1.5rem; }
  .f-social a {
    font-size: .58rem; letter-spacing: .25em; color: var(--dim);
    text-decoration: none; transition: color .2s;
  }
  .f-social a:hover { color: var(--amber3); }

  /* ── Tablet ── */
  @media(max-width:768px) {
    nav { padding: .5rem 1rem; flex-wrap: wrap; gap: .4rem; }
    .nav-l { gap: 1rem; }
    .nav-logo { font-size: 1.3rem; }
    .nav-stat { font-size: .45rem; letter-spacing: .1em; }
    .nav-links { gap: 1rem; }
    .nav-links a { font-size: .52rem; letter-spacing: .15em; }
  }

  /* ── Mobile ── */
