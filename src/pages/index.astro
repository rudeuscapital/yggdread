  </section>

  <!-- DIVIDER -->
  <div class="ascii-div">=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+=+</div>

  <!-- SUPPORTERS -->
  <section class="sup-sec">
    <div class="sec-hd">FORGED BY // CONTRIBUTORS</div>
    <div class="sup-grid">
      {[
        { art: '.-----.\n| S L |\n\'-----\'', name: 'SLADE' },
        { art: '.-----.\n| J Y |\n\'-----\'', name: 'JEFFY YU *' },
        { art: '.-----.\n| /\\  |\n\'-----\'', name: 'GNON LABS' },
